{
  "name": "jiosaavn",
  "version": "1.0.0",
  "description": "A reverse-engineered, professional, fully-typed TypeScript client and specification for the JioSaavn API.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sagarithm/jiosaavn.git"
  },
  "keywords": [
    "jiosaavn",
    "saavn",
    "api",
    "music",
    "streaming",
    "reverse-engineering",
    "typescript"
  ],
  "author": "Sagar Kewat (@sagarithm) & Chirag Vishwakarma (Pixartual Studio)",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/sagarithm/jiosaavn/issues"
  },
  "homepage": "https://github.com/sagarithm/jiosaavn#readme",
  "dependencies": {
    "node-forge": "^1.3.1"
  },
  "devDependencies": {
    "@types/node-forge": "^1.3.11",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^1.4.0"
  }
}
